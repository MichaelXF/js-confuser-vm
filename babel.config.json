{
  "presets": [
    [
      "@babel/preset-env",
      {
        "targets": {
          "node": "18"
        },
        "modules": false
      }
    ],
    ["@babel/preset-typescript"]
  ],
  "plugins": [
    "./babel-plugin-inline-runtime.cjs",
    [
      "replace-import-extension",
      {
        "extMapping": { ".ts": ".js" }
      }
    ]
  ]
}
